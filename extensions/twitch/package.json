{
  "name": "@joopo/twitch",
  "version": "2026.5.6",
  "description": "Joopo Twitch channel plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/joopo/joopo"
  },
  "type": "module",
  "dependencies": {
    "@twurple/api": "^8.1.3",
    "@twurple/auth": "^8.1.3",
    "@twurple/chat": "^8.1.3"
  },
  "devDependencies": {
    "@joopo/plugin-sdk": "workspace:*"
  },
  "joopo": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "install": {
      "npmSpec": "@joopo/twitch",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.5.6"
    },
    "build": {
      "joopoVersion": "2026.5.6"
    },
    "channel": {
      "id": "twitch",
      "label": "Twitch",
      "selectionLabel": "Twitch (Chat)",
      "docsPath": "/channels/twitch",
      "blurb": "Twitch chat integration",
      "aliases": [
        "twitch-chat"
      ]
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
