{
  "name": "@joopo/qqbot",
  "version": "2026.5.6",
  "private": false,
  "description": "Joopo QQ Bot channel plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/joopo/joopo"
  },
  "type": "module",
  "dependencies": {
    "@tencent-connect/qqbot-connector": "^1.1.0",
    "mpg123-decoder": "^1.0.3",
    "silk-wasm": "^3.7.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@joopo/plugin-sdk": "workspace:*",
    "@types/ws": "^8.18.1",
    "joopo": "workspace:*"
  },
  "peerDependencies": {
    "joopo": ">=2026.5.6"
  },
  "peerDependenciesMeta": {
    "joopo": {
      "optional": true
    }
  },
  "joopo": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "qqbot",
      "label": "QQ Bot",
      "selectionLabel": "QQ Bot (Official API)",
      "detailLabel": "QQ Bot",
      "docsPath": "/channels/qqbot",
      "docsLabel": "qqbot",
      "blurb": "connect to QQ via official QQ Bot API with group chat and direct message support.",
      "systemImage": "bubble.left.and.bubble.right"
    },
    "install": {
      "npmSpec": "@joopo/qqbot",
      "localPath": "extensions/qqbot",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.5.6"
    },
    "build": {
      "joopoVersion": "2026.5.6"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
