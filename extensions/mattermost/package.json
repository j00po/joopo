{
  "name": "@joopo/mattermost",
  "version": "2026.5.6",
  "description": "Joopo Mattermost channel plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/joopo/joopo"
  },
  "type": "module",
  "dependencies": {
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@joopo/plugin-sdk": "workspace:*",
    "joopo": "workspace:*"
  },
  "peerDependencies": {
    "joopo": ">=2026.5.6"
  },
  "peerDependenciesMeta": {
    "joopo": {
      "optional": true
    }
  },
  "joopo": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "mattermost",
      "label": "Mattermost",
      "selectionLabel": "Mattermost (plugin)",
      "docsPath": "/channels/mattermost",
      "docsLabel": "mattermost",
      "blurb": "self-hosted Slack-style chat; install the plugin to enable.",
      "order": 65
    },
    "install": {
      "minHostVersion": ">=2026.4.10"
    }
  }
}
