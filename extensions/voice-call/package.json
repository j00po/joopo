{
  "name": "@joopo/voice-call",
  "version": "2026.5.6",
  "description": "Joopo voice-call plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/joopo/joopo"
  },
  "type": "module",
  "dependencies": {
    "commander": "^14.0.3",
    "typebox": "1.1.37",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@joopo/plugin-sdk": "workspace:*",
    "joopo": "workspace:*"
  },
  "peerDependencies": {
    "joopo": ">=2026.5.6"
  },
  "peerDependenciesMeta": {
    "joopo": {
      "optional": true
    }
  },
  "joopo": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@joopo/voice-call",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.5.6"
    },
    "build": {
      "joopoVersion": "2026.5.6"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
